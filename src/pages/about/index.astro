---
import BaseLayout from '../../layouts/BaseLayout.astro';
import company from '../../data/company.json';
---
<BaseLayout
  title="О компании ФЛЕКС РЕНТ — ИП Арасланов · Аренда техники в Усинске"
  description="ИП Арасланов И.Р. — ФЛЕКС РЕНТ. Аренда спецтехники и оборудования в Республике Коми и НАО с 2015 года. Усинск, ул. Парковая 15."
  canonical={`${company.site}/about/`}
  geo={company.geo}
/>

<main>
  <nav class="crumbs" aria-label="Навигация">
    <a href="/">Главная</a>
    <span class="sep" aria-hidden="true">›</span>
    <span aria-current="page">О компании</span>
  </nav>

  <section>
    <p class="section-label">О нас</p>
    <h1 class="section-title" style="font-size:clamp(26px,6vw,38px)">ФЛЕКС РЕНТ — ИП Арасланов</h1>
    <p style="font-size:15px;color:var(--text-dim);line-height:1.65;margin-bottom:20px">
      Компания «ФЛЕКС РЕНТ» под управлением ИП Арасланов И.Р. работает на рынке аренды спецтехники и оборудования с 2015 года. Мы базируемся в Усинске — главном нефтяном городе Республики Коми — и обслуживаем нефтегазовые объекты на всём севере региона и в Ненецком автономном округе.
    </p>
    <p style="font-size:15px;color:var(--text-dim);line-height:1.65;margin-bottom:20px">
      В нашем парке — 35+ единиц собственной техники: автокраны, экскаваторы, краны-манипуляторы, вахтовый транспорт, дизельные генераторы, компрессорные станции, тралы и мобильные вагон-дома. Вся техника в собственности — мы не субарендуем и не накручиваем посреднические наценки.
    </p>

    <div class="features" style="margin-top:24px">
      <div class="feat">
        <div class="feat-top">
          <div class="feat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3>Реквизиты</h3>
        </div>
        <p style="font-size:13px;color:var(--text-dim);line-height:1.8">
          <strong style="color:var(--text)">{company.legalNameFull}</strong><br/>
          ИНН: {company.inn}<br/>
          ОГРНИП: {company.ogrnip}<br/>
          Работаем с {company.founded} года
        </p>
      </div>
      <div class="feat">
        <div class="feat-top">
          <div class="feat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h3>Адрес и регионы</h3>
        </div>
        <p style="font-size:13px;color:var(--text-dim);line-height:1.7">
          <strong style="color:var(--text)">{company.workAddress.addressLocality}</strong>, {company.workAddress.streetAddress}<br/>
          {company.workAddress.addressRegion}<br/>
          Работаем: Республика Коми · НАО<br/>
          Месторождения: Харьяга, Лабаган, Юж.-Ошское
        </p>
      </div>
      <div class="feat">
        <div class="feat-top">
          <div class="feat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <h3>Связь</h3>
        </div>
        <p style="font-size:13px;color:var(--text-dim);line-height:1.7">
          <a href={`tel:${company.phoneTel}`} style="color:var(--accent);font-size:16px;font-weight:700">{company.phoneDisplay}</a><br/>
          <a href={`mailto:${company.email}`} style="color:var(--accent)">{company.email}</a><br/>
          WhatsApp: {company.phoneDisplay}<br/>
          Работаем 24/7
        </p>
      </div>
      <div class="feat">
        <div class="feat-top">
          <div class="feat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          </div>
          <h3>Документы</h3>
        </div>
        <p style="font-size:13px;color:var(--text-dim);line-height:1.7">
          Работаем по 44-ФЗ и 223-ФЗ<br/>
          Полный пакет закрывающих документов<br/>
          Акты · Счета-фактуры · Путевые листы<br/>
          Аккредитация на ЭТП заказчика
        </p>
      </div>
    </div>
  </section>

  <!-- BANK REQUISITES -->
  <section>
    <p class="section-label">Реквизиты для оплаты</p>
    <h2 class="section-title">Банковские реквизиты</h2>
    <div class="req-table">
      <div class="req-row">
        <span class="req-label">Получатель</span>
        <span class="req-value">{company.legalNameFull}</span>
      </div>
      <div class="req-row">
        <span class="req-label">ИНН</span>
        <span class="req-value mono">{company.inn}</span>
      </div>
      <div class="req-row">
        <span class="req-label">ОГРНИП</span>
        <span class="req-value mono">{company.ogrnip}</span>
      </div>
      <div class="req-row">
        <span class="req-label">Банк</span>
        <span class="req-value">{company.bank.name}</span>
      </div>
      <div class="req-row">
        <span class="req-label">БИК</span>
        <span class="req-value mono">{company.bank.bik}</span>
      </div>
      <div class="req-row">
        <span class="req-label">Расчётный счёт</span>
        <span class="req-value mono">{company.bank.rs}</span>
      </div>
      <div class="req-row">
        <span class="req-label">Корр. счёт</span>
        <span class="req-value mono">{company.bank.ks}</span>
      </div>
    </div>
  </section>

  <section>
    <p class="section-label">История</p>
    <h2 class="section-title">10 лет в нефтянке Крайнего Севера</h2>
    <div class="steps">
      <div class="step">
        <div class="step-num" style="font-size:13px">2015</div>
        <div>
          <h3>Основание</h3>
          <p>Регистрация ИП Арасланов. Первые договоры аренды техники для нефтегазовых объектов в Республике Коми.</p>
        </div>
      </div>
      <div class="step">
        <div class="step-num" style="font-size:13px">2018</div>
        <div>
          <h3>Расширение парка</h3>
          <p>Приобретение тяжёлой спецтехники: автокрана КС-55713, экскаватора Volvo. Выход на объекты НАО.</p>
        </div>
      </div>
      <div class="step">
        <div class="step-num" style="font-size:13px">2021</div>
        <div>
          <h3>Крупные заказчики</h3>
          <p>Долгосрочные контракты с ПАО НК «РуссНефть» / ННК, Нобель Ойл, Газпром. Обновление автопарка.</p>
        </div>
      </div>
      <div class="step">
        <div class="step-num" style="font-size:13px">2025</div>
        <div>
          <h3>Сегодня</h3>
          <p>35+ единиц техники, 6+ постоянных заказчиков нефтяной отрасли. Работаем в Коми и НАО круглый год.</p>
        </div>
      </div>
    </div>
  </section>

  <section style="padding-bottom:40px">
    <div class="contact-card">
      <h3>Остались вопросы?</h3>
      <p style="font-size:14px;color:var(--text-dim);margin-bottom:18px">Позвоните или напишите — ответим в течение 15 минут.</p>
      <div style="display:grid;gap:10px">
        <a href={`tel:${company.phoneTel}`} class="btn btn-primary">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
          {company.phoneDisplay}
        </a>
        <a href={`https://wa.me/${company.whatsapp}`} class="btn btn-secondary" rel="nofollow">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.1-.2.3-.8.9-.9 1.1-.2.2-.3.2-.6.1-.3-.1-1.2-.4-2.4-1.5-.9-.8-1.5-1.8-1.6-2.1-.2-.3 0-.4.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5 0-.2 0-.4-.1-.5-.1-.1-.6-1.5-.9-2.1-.2-.5-.5-.4-.7-.5-.2 0-.4 0-.6 0-.2 0-.5.1-.8.4-.3.3-1.1 1.1-1.1 2.7 0 1.6 1.1 3.1 1.3 3.3.2.2 2.3 3.5 5.5 4.8.8.3 1.4.5 1.8.6.8.3 1.5.2 2 .1.6-.1 1.7-.7 2-1.4.2-.7.2-1.2.2-1.4-.1-.2-.3-.3-.6-.4zM12 2a10 10 0 0 0-10 10c0 1.8.5 3.5 1.3 5L2 22l5.1-1.3c1.4.8 3.1 1.3 4.9 1.3a10 10 0 0 0 0-20z"/></svg>
          WhatsApp
        </a>
      </div>
    </div>
  </section>
</main>
