---
import BaseLayout from '../layouts/BaseLayout.astro';
import company from '../data/company.json';
import equipment from '../data/equipment.json';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": company.legalName,
  "alternateName": company.name,
  "description": "Аренда спецтехники, дизельных генераторов и вагон-домов в Республике Коми и НАО",
  "url": company.site,
  "telephone": company.phoneTel,
  "email": company.email,
  "foundingDate": company.founded,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": company.workAddress.streetAddress,
    "addressLocality": company.workAddress.addressLocality,
    "addressRegion": company.workAddress.addressRegion,
    "postalCode": company.workAddress.postalCode,
    "addressCountry": "RU"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": company.geo.lat,
    "longitude": company.geo.lon
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": company.rating.value,
    "reviewCount": company.rating.count
  }
};

const iconMap: Record<string, string> = {
  crane: `<path d="M12 2v6m0 0l-4 4m4-4l4 4M4 22h16M8 22V12H4l8-10 8 10h-4v10"/>`,
  excavator: `<path d="M2 20h20M6 20V10l4-6h4l4 6v10M10 20v-5h4v5"/>`,
  kmu: `<path d="M1 12h4l2-8h10l2 8h4M5 12v8h14v-8M9 20v-4h6v4"/>`,
  bus: `<rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5h-7V8zM5.5 21a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3zM18.5 21a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3z"/>`,
  car: `<path d="M5 17H3a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v9a2 2 0 0 1-2 2h-2"/><circle cx="9" cy="17" r="2"/><circle cx="17" cy="17" r="2"/>`,
  generator: `<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>`,
  home: `<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>`,
  special: `<path d="M12 22V12M12 12L4 7.5M12 12l8-4.5M4 7.5V17L12 22M20 7.5V17L12 22M4 7.5L12 3l8 4.5"/>`,
};
---
<BaseLayout
  title="ФЛЕКС РЕНТ — Аренда спецтехники в Республике Коми и НАО | Усинск"
  description="Аренда автокранов, экскаваторов, КМУ, вахтовок, генераторов и вагон-домов в Республике Коми и НАО. Работаем с нефтегазовыми объектами. Усинск. ИП Арасланов."
  keywords="аренда спецтехники Усинск, аренда автокрана Коми, аренда экскаватора НАО, вагон-дом аренда, дизельный генератор аренда Коми, КМУ аренда Усинск"
  canonical={company.site + '/'}
  geo={company.geo}
  jsonLd={jsonLd}
/>

<main>
  <!-- HERO -->
  <section class="hero">
      <div class="hero-badge">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:13px;height:13px"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/></svg>
        Усинск · Коми · НАО
      </div>
      <h1>Аренда спецтехники<br/>и оборудования<br/>в <em>нефтегазовом</em> секторе</h1>
      <p class="hero-sub">
        Краны, экскаваторы, КМУ, вахтовки, дизельные генераторы и вагон-дома.
        Работаем на объектах Харьяги, Нобель Ойл, ННК и других месторождениях Крайнего Севера.
      </p>
      <div class="trust-strip">
        <span class="trust-chip">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          35+ единиц техники
        </span>
        <span class="trust-chip">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          Работаем с 2015 года
        </span>
        <span class="trust-chip">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          Выезд 24/7
        </span>
        <span class="trust-chip">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          44-ФЗ и 223-ФЗ
        </span>
      </div>
      <div class="cta-group">
        <a href={`tel:${company.phoneTel}`} class="btn btn-primary">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
          Позвонить: {company.phoneDisplay}
        </a>
        <a href="/park/" class="btn btn-secondary">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 3h15v13H1zM16 8h4l3 3v5h-7"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          Весь парк техники
        </a>
      </div>
  </section>

  <!-- STATS -->
  <div class="stats">
    {equipment.stats.map(s => (
      <div class="stat">
        <div class="stat-num">{s.num}</div>
        <div class="stat-label">{s.label}</div>
      </div>
    ))}
  </div>

  <!-- CATEGORIES -->
  <section>
    <p class="section-label">Что сдаём в аренду</p>
    <h2 class="section-title">Парк техники и оборудования</h2>
    <p class="section-sub">Собственный парк — без посредников. Вся техника в собственности ИП Арасланов и ООО НМА, регулярно проходит ТО.</p>
    <div class="categories">
      {equipment.categories.map(cat => (
        <a href={`/park/#${cat.slug}`} class="cat">
          <div class="cat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={iconMap[cat.icon] ?? iconMap.special} />
          </div>
          <h3>{cat.name}</h3>
          <p>{cat.description.slice(0, 90)}…</p>
          <span class="cat-tag">
            {cat.units.filter(u => u.status === 'available').length > 0
              ? `${cat.units.filter(u => u.status === 'available').length} ед. доступно`
              : 'Уточнить наличие'}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- VAGONY HIGHLIGHT -->
  <section id="vagony" style="padding-top:0">
    <p class="section-label">Вахтовое обустройство</p>
    <h2 class="section-title">Мобильные вагон-дома</h2>
    <p class="section-sub">Утеплённые жилые, офисные модули и бани для обустройства вахтовых посёлков в условиях Крайнего Севера.</p>
    <div class="vagony-cards">
      <div class="vagony-card">
        <div class="vagony-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        </div>
        <h3>Вагон-дом жилой</h3>
        <p>Утеплённые жилые модули на 6–8 мест. Северное исполнение, обогрев, освещение, спальные места.</p>
        <div class="vagony-features">
          <div class="vagony-feat">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Северное утепление
          </div>
          <div class="vagony-feat">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            6–8 спальных мест
          </div>
          <div class="vagony-feat">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Электроотопление + резерв
          </div>
        </div>
      </div>
      <div class="vagony-card">
        <div class="vagony-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
        </div>
        <h3>Вагон-офис</h3>
        <p>Мобильный офис для ИТР и руководства объекта. Рабочие места, освещение, отопление.</p>
        <div class="vagony-features">
          <div class="vagony-feat">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Мебель и освещение
          </div>
          <div class="vagony-feat">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Отопление / кондиционер
          </div>
          <div class="vagony-feat">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Быстрая доставка на объект
          </div>
        </div>
      </div>
      <div class="vagony-card">
        <div class="vagony-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M8 22H6a2 2 0 0 1-2-2V6l4-4h8l4 4v14a2 2 0 0 1-2 2h-2"/><path d="M8 22v-8h8v8"/><path d="M12 10a2 2 0 0 0 0 4"/></svg>
        </div>
        <h3>Вагон-баня</h3>
        <p>Мобильная баня для вахтового персонала. Парная, помывочная, предбанник. Дровяная печь.</p>
        <div class="vagony-features">
          <div class="vagony-feat">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Парная + помывочная
          </div>
          <div class="vagony-feat">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Дровяная печь
          </div>
          <div class="vagony-feat">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Аренда от 1 месяца
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section>
    <p class="section-label">Процесс работы</p>
    <h2 class="section-title">Как арендовать технику</h2>
    <p class="section-sub">Работаем быстро и прозрачно. Полный пакет документов для отчётности.</p>
    <div class="steps">
      <div class="step">
        <div class="step-num">1</div>
        <div>
          <h3>Оставьте заявку</h3>
          <p>Позвоните или напишите в WhatsApp. Уточним, какая техника нужна, срок и объект.</p>
        </div>
      </div>
      <div class="step">
        <div class="step-num">2</div>
        <div>
          <h3>КП и договор</h3>
          <p>Направим коммерческое предложение и проект договора аренды. Работаем по 44-ФЗ и 223-ФЗ.</p>
        </div>
      </div>
      <div class="step">
        <div class="step-num">3</div>
        <div>
          <h3>Подача техники</h3>
          <p>После подписания договора и предоплаты техника подаётся на объект — от 1 рабочего дня.</p>
        </div>
      </div>
      <div class="step">
        <div class="step-num">4</div>
        <div>
          <h3>Закрывающие документы</h3>
          <p>Ежемесячно предоставляем акты, счета-фактуры, путевые листы для бухгалтерии.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY US -->
  <section>
    <p class="section-label">Наши преимущества</p>
    <h2 class="section-title">Почему выбирают ФЛЕКС РЕНТ</h2>
    <div class="features">
      <div class="feat">
        <div class="feat-top">
          <div class="feat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3>Собственный парк</h3>
        </div>
        <p>Вся техника в собственности — нет посредников, нет наценок субаренды. Вы работаете напрямую с владельцем.</p>
      </div>
      <div class="feat">
        <div class="feat-top">
          <div class="feat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          </div>
          <h3>Выезд 24/7</h3>
        </div>
        <p>Работаем круглосуточно. Аварийный выезд на объект доступен в любое время суток, включая праздники.</p>
      </div>
      <div class="feat">
        <div class="feat-top">
          <div class="feat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          </div>
          <h3>Полная документация</h3>
        </div>
        <p>Договоры, акты выполненных работ, счета-фактуры, путевые листы — всё для бухгалтерии и отчётности заказчика.</p>
      </div>
      <div class="feat">
        <div class="feat-top">
          <div class="feat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3>Опытные операторы</h3>
        </div>
        <p>Все машинисты и водители имеют допуски к работе на нефтегазовых объектах, удостоверения и опыт в Арктике.</p>
      </div>
      <div class="feat">
        <div class="feat-top">
          <div class="feat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h3>Знание региона</h3>
        </div>
        <p>Базируемся в Усинске с 2015 года. Знаем специфику дорог, зимников и удалённых объектов Коми и НАО.</p>
      </div>
      <div class="feat">
        <div class="feat-top">
          <div class="feat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
          <h3>Гибкие условия</h3>
        </div>
        <p>Аренда от 1 смены, помесячно или на весь сезон. Индивидуальные цены для долгосрочных заказчиков.</p>
      </div>
    </div>
  </section>

  <!-- CLIENTS -->
  <section>
    <p class="section-label">Наши заказчики</p>
    <h2 class="section-title">Работаем с лидерами нефтянки</h2>
    <p class="section-sub">Имеем опыт длительной работы на объектах ведущих нефтегазодобывающих компаний Тимано-Печорской провинции.</p>
    <div class="clients-grid">
      {equipment.clients.map(c => (
        <div class="client">
          <div class="client-check">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <div class="client-name">{c.name}</div>
            <div class="client-desc">{c.desc}</div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- FAQ -->
  <section>
    <p class="section-label">Вопросы и ответы</p>
    <h2 class="section-title">Частые вопросы</h2>
    <div class="faq">
      {equipment.faq.map(item => (
        <details class="qa">
          <summary>{item.q}</summary>
          <div class="qa-body">{item.a}</div>
        </details>
      ))}
    </div>
  </section>

  <!-- CONTACT -->
  <section>
    <p class="section-label">Контакты</p>
    <h2 class="section-title">Свяжитесь с нами</h2>
    <p class="section-sub">Ответим на вопросы, подберём технику под задачу и отправим коммерческое предложение.</p>
    <div class="contact-card">
      <h3>ФЛЕКС РЕНТ · ИП Арасланов</h3>
      <div class="contact-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
        <div>
          <a href={`tel:${company.phoneTel}`}>{company.phoneDisplay}</a>
          <small>Звонок + WhatsApp · 24/7</small>
        </div>
      </div>
      <div class="contact-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><path d="M22 6l-10 7L2 6"/></svg>
        <div>
          <a href={`mailto:${company.email}`}>{company.email}</a>
          <small>Email для заявок и документов</small>
        </div>
      </div>
      <div class="contact-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <div>
          <a href="#">{company.workAddress.addressLocality}, {company.workAddress.streetAddress}</a>
          <small>{company.workAddress.addressRegion} · база и офис</small>
        </div>
      </div>
      <div class="contact-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <div>
          <span style="color:var(--text);font-weight:600">Республика Коми · НАО</span>
          <small>Основные регионы работы</small>
        </div>
      </div>
      <div style="margin-top:18px;display:grid;gap:10px">
        <a href={`tel:${company.phoneTel}`} class="btn btn-primary">
